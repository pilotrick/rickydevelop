<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_stock_intelligence" model="ir.cron">
            <field name="name">Purchase Intelligence: Análisis Automático de Stock</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">model.action_recalculate_all_stock_intelligence()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_calculate_daily_kpis" model="ir.cron">
            <field name="name">Purchase Intelligence: Calcular KPIs Diarios</field>
            <field name="model_id" ref="Purchase_advance_astra.model_purchase_intelligence_kpi"/>
            <field name="state">code</field>
            <field name="code">model.action_calculate_daily_warehouse_kpis()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_check_alerts" model="ir.cron">
            <field name="name">Purchase Intelligence: Verificar Alertas</field>
            <field name="model_id" ref="Purchase_advance_astra.model_purchase_intelligence_alert"/>
            <field name="state">code</field>
            <field name="code">model.check_and_generate_alerts()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_generate_reorder_optimizations" model="ir.cron">
            <field name="name">Purchase Intelligence: Optimización de Reorden Automática</field>
            <field name="model_id" ref="Purchase_advance_astra.model_pi_reorder_optimization"/>
            <field name="state">code</field>
            <field name="code">model.action_generate_all_optimizations()</field>
            <field name="interval_number">3</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_generate_supplier_scorecards" model="ir.cron">
            <field name="name">Purchase Intelligence: Evaluación Automática de Proveedores</field>
            <field name="model_id" ref="Purchase_advance_astra.model_pi_supplier_scorecard"/>
            <field name="state">code</field>
            <field name="code">model.action_generate_all_scorecards()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_generate_order_suggestions" model="ir.cron">
            <field name="name">Purchase Intelligence: Sugerencias de Órdenes Automáticas</field>
            <field name="model_id" ref="Purchase_advance_astra.model_pi_automated_order"/>
            <field name="state">code</field>
            <field name="code">model.generate_automated_suggestions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_update_forecasts" model="ir.cron">
            <field name="name">Purchase Intelligence: Pronósticos de Demanda Automáticos</field>
            <field name="model_id" ref="Purchase_advance_astra.model_purchase_intelligence_forecast"/>
            <field name="state">code</field>
            <field name="code">model.action_update_forecasts()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_stockout_prevention" model="ir.cron">
            <field name="name">Purchase Intelligence: Prevención de Roturas</field>
            <field name="model_id" ref="Purchase_advance_astra.model_pi_stockout_prevention"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_all_prevention_records()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_warehouse_intelligence" model="ir.cron">
            <field name="name">Purchase Intelligence: Inteligencia por Almacén</field>
            <field name="model_id" ref="Purchase_advance_astra.model_warehouse_intelligence"/>
            <field name="state">code</field>
            <field name="code">model.action_generate_warehouse_intelligence()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        
        <record id="ir_cron_smart_transfer" model="ir.cron">
            <field name="name">Purchase Intelligence: Sugerencias de Transferencia IA</field>
            <field name="model_id" ref="Purchase_advance_astra.model_pi_smart_transfer"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_transfer_suggestions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
