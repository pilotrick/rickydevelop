<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Reporte de Inteligencia por Almacén -->
        <report
            id="report_warehouse_intelligence"
            model="warehouse.intelligence"
            string="Inteligencia de Almacén"
            report_type="qweb-pdf"
            name="purchase_advance_astra.report_warehouse_intelligence"
            file="purchase_advance_astra.report_warehouse_intelligence"
            print_report_name="'Inteligencia_Almacen_%s' % (object.warehouse_id.name)"
            binding_model="warehouse.intelligence"
            binding_type="report"
        />

        <!-- Reporte Comparativo de Almacenes -->
        <report
            id="report_warehouse_comparison"
            model="warehouse.intelligence"
            string="Comparación de Almacenes"
            report_type="qweb-pdf"
            name="purchase_advance_astra.report_warehouse_comparison"
            file="purchase_advance_astra.report_warehouse_comparison"
            print_report_name="'Comparacion_Almacenes_%s' % (object.date.strftime('%Y%m%d'))"
            binding_model="warehouse.intelligence"
            binding_type="report"
        />

        <!-- Reporte de KPIs por Almacén -->
        <report
            id="report_warehouse_kpis"
            model="purchase.intelligence.kpi"
            string="KPIs por Almacén"
            report_type="qweb-pdf"
            name="purchase_advance_astra.report_warehouse_kpis"
            file="purchase_advance_astra.report_warehouse_kpis"
            print_report_name="'KPIs_Almacen_%s_%s' % (object.warehouse_id.name, object.date.strftime('%Y%m%d'))"
            binding_model="purchase.intelligence.kpi"
            binding_type="report"
        />

        <!-- Reporte de Sugerencias de Reorden por Almacén -->
        <report
            id="report_warehouse_reorder_suggestions"
            model="pi.automated.order"
            string="Sugerencias de Reorden por Almacén"
            report_type="qweb-pdf"
            name="purchase_advance_astra.report_warehouse_reorder_suggestions"
            file="purchase_advance_astra.report_warehouse_reorder_suggestions"
            print_report_name="'Reorden_Almacen_%s_%s' % (object.warehouse_id.name, object.create_date.strftime('%Y%m%d'))"
            binding_model="pi.automated.order"
            binding_type="report"
        />

        <!-- Plantilla: Reporte de Inteligencia por Almacén -->
        <template id="report_warehouse_intelligence">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Encabezado -->
                            <div class="row">
                                <div class="col-6">
                                    <h2>📊 Inteligencia de Almacén</h2>
                                    <h3 t-field="o.warehouse_id.name"/>
                                </div>
                                <div class="col-6 text-right">
                                    <p><strong>Fecha:</strong> <span t-field="o.date"/></p>
                                    <p><strong>Generado:</strong> <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/></p>
                                </div>
                            </div>
                            <hr/>

                            <!-- Métricas Principales -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h3>📋 Métricas Principales</h3>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h4 class="card-title" t-field="o.total_products"/>
                                            <p class="card-text">Total Productos</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h4 class="card-title" t-field="o.critical_products"/>
                                            <p class="card-text">Productos Críticos</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h4 class="card-title" t-field="o.products_need_reorder"/>
                                            <p class="card-text">Necesitan Reorden</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h4 class="card-title"><t t-esc="'%.1f%%' % o.stock_availability"/></h4>
                                            <p class="card-text">Disponibilidad</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Análisis de Inventario -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h3>📦 Análisis de Inventario</h3>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <h4>Valores Monetarios</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Valor Total Stock:</strong></td>
                                            <td class="text-right"><t t-esc="'${:,.2f}'.format(o.total_stock_value)"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Valor Órdenes Pendientes:</strong></td>
                                            <td class="text-right"><t t-esc="'${:,.2f}'.format(o.pending_order_value)"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Gasto Mensual:</strong></td>
                                            <td class="text-right"><t t-esc="'${:,.2f}'.format(o.monthly_spend)"/></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h4>KPIs de Inventario</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Rotación:</strong></td>
                                            <td class="text-right"><t t-esc="'%.2fx' % o.stock_turnover"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Días Inventario:</strong></td>
                                            <td class="text-right"><t t-esc="'%.1f días' % o.days_of_inventory"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Tasa Rotura:</strong></td>
                                            <td class="text-right"><t t-esc="'%.2f%%' % o.stockout_rate"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Análisis ABC -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h3>📊 Análisis ABC</h3>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-4">
                                    <div class="card border-success">
                                        <div class="card-header bg-success text-white">
                                            <h5>Clase A</h5>
                                        </div>
                                        <div class="card-body">
                                            <p><strong>Productos:</strong> <t t-field="o.abc_a_count"/></p>
                                            <p><strong>Valor:</strong> <t t-esc="'${:,.2f}'.format(o.abc_a_value)"/></p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card border-warning">
                                        <div class="card-header bg-warning text-white">
                                            <h5>Clase B</h5>
                                        </div>
                                        <div class="card-body">
                                            <p><strong>Productos:</strong> <t t-field="o.abc_b_count"/></p>
                                            <p><strong>Valor:</strong> <t t-esc="'${:,.2f}'.format(o.abc_b_value)"/></p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card border-info">
                                        <div class="card-header bg-info text-white">
                                            <h5>Clase C</h5>
                                        </div>
                                        <div class="card-body">
                                            <p><strong>Productos:</strong> <t t-field="o.abc_c_count"/></p>
                                            <p><strong>Valor:</strong> <t t-esc="'${:,.2f}'.format(o.abc_c_value)"/></p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Métricas de Proveedores -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h3>🚚 Métricas de Proveedores</h3>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Proveedores Activos:</strong></td>
                                            <td><t t-field="o.active_suppliers"/></td>
                                            <td><strong>Tasa Entrega a Tiempo:</strong></td>
                                            <td><t t-esc="'%.1f%%' % o.on_time_delivery_rate"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Tiempo Promedio Entrega:</strong></td>
                                            <td><t t-esc="'%.1f días' % o.avg_delivery_time"/></td>
                                            <td><strong>Calidad Promedio:</strong></td>
                                            <td><t t-esc="'%.1f/10' % o.avg_quality_score"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Alertas -->
                            <div t-if="o.alert_count > 0" class="row mt-4">
                                <div class="col-12">
                                    <h3>⚠️ Alertas</h3>
                                    <div class="alert alert-danger">
                                        <h5><t t-esc="o.alert_count"/> Alertas Activas</h5>
                                        <p t-raw="o.critical_alerts"/>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Plantilla: Reporte Comparativo de Almacenes -->
        <template id="report_warehouse_comparison">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Encabezado -->
                        <div class="row">
                            <div class="col-12 text-center">
                                <h2>📊 Comparación de Almacenes</h2>
                                <p><strong>Fecha:</strong> <span t-field="o.date"/></p>
                            </div>
                        </div>
                        <hr/>

                        <!-- Tabla Comparativa -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <h3>📋 Métricas Comparativas</h3>
                                <table class="table table-striped table-bordered">
                                    <thead class="thead-dark">
                                        <tr>
                                            <th>Almacén</th>
                                            <th>Eficiencia</th>
                                            <th>Rank</th>
                                            <th>Productos</th>
                                            <th>Críticos</th>
                                            <th>Disponibilidad</th>
                                            <th>Gasto Mensual</th>
                                            <th>Rotación</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.get_warehouse_comparison_data()['comparison_data']" t-as="warehouse">
                                            <td t-field="warehouse.warehouse_name"/>
                                            <td>
                                                <div class="progress">
                                                    <div class="progress-bar" 
                                                         t-att-style="'width: ' + str(warehouse.efficiency_score) + '%'"
                                                         role="progressbar">
                                                        <t t-esc="'%.1f%%' % warehouse.efficiency_score"/>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>#<t t-field="warehouse.performance_rank"/></td>
                                            <td t-field="warehouse.total_products"/>
                                            <td t-field="warehouse.critical_products"/>
                                            <td><t t-esc="'%.1f%%' % warehouse.stock_availability"/></td>
                                            <td><t t-esc="'${:,.2f}'.format(warehouse.monthly_spend)"/></td>
                                            <td><t t-esc="'%.2fx' % warehouse.stock_turnover"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Mejor y Peor Almacén -->
                        <div class="row mt-4">
                            <div class="col-6">
                                <div class="card border-success">
                                    <div class="card-header bg-success text-white">
                                        <h4>🏆 Mejor Almacén</h4>
                                    </div>
                                    <div class="card-body">
                                        <h5 t-field="o.get_warehouse_comparison_data()['best_warehouse']['warehouse_name']"/>
                                        <p><strong>Rank:</strong> #<t t-field="o.get_warehouse_comparison_data()['best_warehouse']['performance_rank']"/></p>
                                        <p><strong>Eficiencia:</strong> <t t-esc="'%.1f%%' % o.get_warehouse_comparison_data()['best_warehouse']['efficiency_score']"/></p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-danger">
                                    <div class="card-header bg-danger text-white">
                                        <h4>🔴 Almacén a Mejorar</h4>
                                    </div>
                                    <div class="card-body">
                                        <h5 t-field="o.get_warehouse_comparison_data()['worst_warehouse']['warehouse_name']"/>
                                        <p><strong>Rank:</strong> #<t t-field="o.get_warehouse_comparison_data()['worst_warehouse']['performance_rank']"/></p>
                                        <p><strong>Eficiencia:</strong> <t t-esc="'%.1f%%' % o.get_warehouse_comparison_data()['worst_warehouse']['efficiency_score']"/></p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Rankings por KPI -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <h3>🏆 Rankings por KPI</h3>
                                <div class="row">
                                    <div class="col-6">
                                        <h5>Disponibilidad de Stock</h5>
                                        <table class="table table-sm">
                                            <tr t-foreach="o.get_warehouse_comparison_data()['rankings']['stock_availability'][:5]" t-as="rank">
                                                <td>#<t t-field="rank.rank"/></td>
                                                <td t-field="rank.warehouse_name"/></td>
                                                <td><t t-esc="'%.1f%%' % rank.value"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="col-6">
                                        <h5>Rotación de Inventario</h5>
                                        <table class="table table-sm">
                                            <tr t-foreach="o.get_warehouse_comparison_data()['rankings']['turnover'][:5]" t-as="rank">
                                                <td>#<t t-field="rank.rank"/></td>
                                                <td t-field="rank.warehouse_name"/></td>
                                                <td><t t-esc="'%.2fx' % rank.value"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </template>

        <!-- Plantilla: Reporte de KPIs por Almacén -->
        <template id="report_warehouse_kpis">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Encabezado -->
                            <div class="row">
                                <div class="col-6">
                                    <h2>📊 KPIs por Almacén</h2>
                                    <h3 t-field="o.warehouse_id.name"/>
                                </div>
                                <div class="col-6 text-right">
                                    <p><strong>Fecha:</strong> <span t-field="o.date"/></p>
                                    <p><strong>Tipo KPI:</strong> <span t-field="o.kpi_type"/></p>
                                </div>
                            </div>
                            <hr/>

                            <!-- Valor del KPI -->
                            <div class="row mt-4">
                                <div class="col-12 text-center">
                                    <div class="card">
                                        <div class="card-body">
                                            <h2 t-field="o.value"/>
                                            <h4 t-field="o.name"/></h4>
                                            <p t-field="o.description"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contexto Adicional -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h4>Contexto del KPI</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Rank del Almacén:</strong></td>
                                            <td>#<t t-field="o.warehouse_rank"/></td>
                                            <td><strong>Score de Rendimiento:</strong></td>
                                            <td><t t-esc="'%.1f/100' % o.warehouse_performance_score"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Datos de Comparación -->
                            <div t-if="o.warehouse_comparison_data" class="row mt-4">
                                <div class="col-12">
                                    <h4>Comparación con Otros Almacenes</h4>
                                    <div class="alert alert-info">
                                        <pre t-raw="o.warehouse_comparison_data"/>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Plantilla: Reporte de Sugerencias de Reorden por Almacén -->
        <template id="report_warehouse_reorder_suggestions">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Encabezado -->
                            <div class="row">
                                <div class="col-6">
                                    <h2>📋 Sugerencia de Reorden</h2>
                                    <h3 t-field="o.warehouse_id.name"/>
                                </div>
                                <div class="col-6 text-right">
                                    <p><strong>Producto:</strong> <span t-field="o.product_id.name"/></p>
                                    <p><strong>Fecha:</strong> <span t-field="o.create_date"/></p>
                                </div>
                            </div>
                            <hr/>

                            <!-- Información Principal -->
                            <div class="row mt-4">
                                <div class="col-6">
                                    <h4>Información del Producto</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Producto:</strong></td>
                                            <td t-field="o.product_id.name"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Código:</strong></td>
                                            <td t-field="o.product_id.default_code"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Categoría:</strong></td>
                                            <td t-field="o.product_id.categ_id.name"/>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h4>Estado Actual en Almacén</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Stock Actual:</strong></td>
                                            <td t-field="o.warehouse_stock_level"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Punto Reorden:</strong></td>
                                            <td t-field="o.warehouse_reorder_point"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Stock Seguridad:</strong></td>
                                            <td t-field="o.warehouse_safety_stock"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Días Stock:</strong></td>
                                            <td><t t-esc="'%.1f días' % o.warehouse_days_of_stock"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Sugerencia -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header">
                                            <h4>📋 Sugerencia de Reorden</h4>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-6">
                                                    <table class="table table-striped">
                                                        <tr>
                                                            <td><strong>Cantidad Sugerida:</strong></td>
                                                            <td t-field="o.suggested_quantity"/>
                                                        </tr>
                                                        <tr>
                                                            <td><strong>Costo Estimado:</strong></td>
                                                            <td><t t-esc="'${:,.2f}'.format(o.estimated_cost)"/></td>
                                                        </tr>
                                                        <tr>
                                                            <td><strong>Urgencia:</strong></td>
                                                            <td t-field="o.urgency_level"/>
                                                        </tr>
                                                    </table>
                                                </div>
                                                <div class="col-6">
                                                    <h5>Justificación</h5>
                                                    <p t-field="o.reason"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Métricas de Consumo -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h4>📊 Métricas de Consumo</h4>
                                    <table class="table table-striped">
                                        <tr>
                                            <td><strong>Uso Diario:</strong></td>
                                            <td t-field="o.warehouse_daily_usage"/>
                                        </tr>
                                        <tr>
                                            <td><strong>Uso Semanal:</strong></td>
                                            <td><t t-esc="'%.1f' % (o.warehouse_daily_usage * 7)"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Uso Mensual:</strong></td>
                                            <td><t t-esc="'%.1f' % (o.warehouse_daily_usage * 30)"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Score Prioridad:</strong></td>
                                            <td><t t-esc="'%.1f/100' % o.warehouse_priority_score"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>