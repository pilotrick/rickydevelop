<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="purchase_intelligence.InventoryIntelligenceDashboard">
        <div class="o_purchase_intelligence_dashboard">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Inventory Intelligence Center</h2>
                <button class="btn btn-primary" t-on-click="refreshData">
                    <i class="fa fa-refresh"/> Refresh
                </button>
            </div>

            <t t-if="state.loading">
                <div class="text-center p-5">
                    <i class="fa fa-spinner fa-spin fa-3x"/>
                    <p class="mt-3">Loading inventory data...</p>
                </div>
            </t>

            <t t-else="">
                <!-- Inventory Metrics Summary -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <h6 class="card-title">Total Inventory Value</h6>
                                <h3><t t-esc="formatCurrency(state.data.inventory_metrics.total_value)"/></h3>
                                <small>Across all locations</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body">
                                <h6 class="card-title">Stock Availability</h6>
                                <h3><t t-esc="state.data.inventory_metrics.availability"/>%</h3>
                                <small>In-stock products</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-white">
                            <div class="card-body">
                                <h6 class="card-title">Inventory Turnover</h6>
                                <h3><t t-esc="state.data.inventory_metrics.turnover.toFixed(1)"/>x</h3>
                                <small>Annual rotation</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-danger text-white">
                            <div class="card-body">
                                <h6 class="card-title">Stockout Risk</h6>
                                <h3><t t-esc="state.data.inventory_metrics.stockout_count"/></h3>
                                <small>Critical items</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ABC Analysis -->
                <div class="row mb-4">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h5>ABC Analysis - Inventory Distribution</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="text-center p-3 border rounded">
                                            <h6 class="text-danger">Class A - High Value</h6>
                                            <h3><t t-esc="state.data.abc_analysis.a_count"/> items</h3>
                                            <p class="mb-0"><t t-esc="formatCurrency(state.data.abc_analysis.a_value)"/></p>
                                            <small class="text-muted"><t t-esc="state.data.abc_analysis.a_percent"/>% of total value</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-3 border rounded">
                                            <h6 class="text-warning">Class B - Medium Value</h6>
                                            <h3><t t-esc="state.data.abc_analysis.b_count"/> items</h3>
                                            <p class="mb-0"><t t-esc="formatCurrency(state.data.abc_analysis.b_value)"/></p>
                                            <small class="text-muted"><t t-esc="state.data.abc_analysis.b_percent"/>% of total value</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-3 border rounded">
                                            <h6 class="text-success">Class C - Low Value</h6>
                                            <h3><t t-esc="state.data.abc_analysis.c_count"/> items</h3>
                                            <p class="mb-0"><t t-esc="formatCurrency(state.data.abc_analysis.c_value)"/></p>
                                            <small class="text-muted"><t t-esc="state.data.abc_analysis.c_percent"/>% of total value</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Critical Stock Levels -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5>Critical Stock Levels</h5>
                                <span class="badge badge-danger"><t t-esc="state.data.stockout_risks.length"/> items</span>
                            </div>
                            <div class="card-body">
                                <t t-if="state.data.stockout_risks.length > 0">
                                    <div class="list-group">
                                        <t t-foreach="state.data.stockout_risks" t-as="item" t-key="item.id">
                                            <a href="#" class="list-group-item list-group-item-action" t-on-click="() => this.viewProduct(item.id)">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1"><t t-esc="item.name"/></h6>
                                                        <small>
                                                            Stock: <t t-esc="formatNumber(item.qty_available)"/> units
                                                            | ROP: <t t-esc="formatNumber(item.reorder_point)"/>
                                                        </small>
                                                    </div>
                                                    <div class="text-right">
                                                        <span t-att-class="'badge badge-' + (item.coverage_days &lt; 3 ? 'danger' : 'warning')">
                                                            <t t-esc="item.coverage_days.toFixed(1)"/> days
                                                        </span>
                                                    </div>
                                                </div>
                                            </a>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <p class="text-muted text-center py-4">No critical stock levels detected</p>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Reorder Suggestions -->
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5>Reorder Suggestions</h5>
                                <button class="btn btn-sm btn-primary" t-on-click="viewReorderSuggestions">
                                    View All
                                </button>
                            </div>
                            <div class="card-body">
                                <t t-if="state.data.reorder_suggestions.length > 0">
                                    <div class="list-group">
                                        <t t-foreach="state.data.reorder_suggestions" t-as="suggestion" t-key="suggestion.id">
                                            <div class="list-group-item">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <h6 class="mb-1"><t t-esc="suggestion.product_name"/></h6>
                                                        <small class="text-muted">
                                                            Suggested: <t t-esc="formatNumber(suggestion.suggested_qty)"/> units
                                                            | Supplier: <t t-esc="suggestion.supplier_name or 'TBD'"/>
                                                        </small>
                                                    </div>
                                                    <span t-att-class="'badge badge-' + (suggestion.urgency === 'critical' ? 'danger' : suggestion.urgency === 'high' ? 'warning' : 'info')">
                                                        <t t-esc="suggestion.urgency.toUpperCase()"/>
                                                    </span>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <p class="text-muted text-center py-4">No reorder suggestions at this time</p>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stock Coverage by Category -->
                <div class="row">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h5>Stock Coverage by Category</h5>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <tr>
                                            <th>Category</th>
                                            <th class="text-right">Current Stock</th>
                                            <th class="text-right">Daily Usage</th>
                                            <th class="text-right">Coverage Days</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.stock_levels" t-as="level" t-key="level.category">
                                            <tr>
                                                <td><t t-esc="level.category"/></td>
                                                <td class="text-right"><t t-esc="formatNumber(level.current_stock)"/></td>
                                                <td class="text-right"><t t-esc="formatNumber(level.daily_usage)"/></td>
                                                <td class="text-right">
                                                    <span t-att-class="getStockLevelClass(level.coverage_days)">
                                                        <t t-esc="level.coverage_days.toFixed(1)"/>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <i t-att-class="'fa ' + getStockLevelIcon(level.coverage_days) + ' ' + getStockLevelClass(level.coverage_days)"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
