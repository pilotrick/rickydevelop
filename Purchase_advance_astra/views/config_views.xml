<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_purchase_intelligence_config_tree" model="ir.ui.view">
        <field name="name">purchase.intelligence.config.tree</field>
        <field name="model">purchase.intelligence.config</field>
        <field name="arch" type="xml">
            <list string="Configuraciones">
                <field name="name"/>
                <field name="service_level_target"/>
                <field name="holding_cost_percentage"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_intelligence_config_form" model="ir.ui.view">
        <field name="name">purchase.intelligence.config.form</field>
        <field name="model">purchase.intelligence.config</field>
        <field name="arch" type="xml">
            <form string="Configuración">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Configuración General">
                            <field name="active"/>
                            <field name="service_level_target"/>
                            <field name="holding_cost_percentage"/>
                            <field name="ordering_cost"/>
                        </group>
                    </group>
                    <group string="Ponderaciones del Cuadro de Mando de Proveedores">
                        <group>
                            <field name="weight_quality"/>
                            <field name="weight_delivery"/>
                            <field name="weight_price"/>
                        </group>
                        <group>
                            <field name="weight_service"/>
                            <field name="weight_innovation"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Config Action -->
    <record id="action_purchase_intelligence_config" model="ir.actions.act_window">
        <field name="name">Ajustes de Inteligencia de Compras</field>
        <field name="res_model">purchase.intelligence.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
