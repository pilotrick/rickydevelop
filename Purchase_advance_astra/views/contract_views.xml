<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_pi_contract_tree" model="ir.ui.view">
        <field name="name">pi.contract.tree</field>
        <field name="model">pi.contract</field>
        <field name="arch" type="xml">
            <list string="Contratos de Compra">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="contract_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_value" widget="monetary"/>
                <field name="utilized_value" widget="monetary"/>
                <field name="utilization_percentage" widget="percentage"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'active'" 
                       decoration-danger="status == 'expired'" 
                       decoration-warning="status == 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_pi_contract_form" model="ir.ui.view">
        <field name="name">pi.contract.form</field>
        <field name="model">pi.contract</field>
        <field name="arch" type="xml">
            <form string="Contrato de Compra">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="contract_type"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group string="Valores">
                        <group>
                            <field name="total_value" widget="monetary"/>
                            <field name="utilized_value" widget="monetary"/>
                        </group>
                        <group>
                            <field name="utilization_percentage" widget="percentage"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_pi_contract_calendar" model="ir.ui.view">
        <field name="name">pi.contract.calendar</field>
        <field name="model">pi.contract</field>
        <field name="arch" type="xml">
            <calendar string="Contratos" date_start="start_date" date_stop="end_date" color="status">
                <field name="name"/>
                <field name="partner_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_pi_contract" model="ir.actions.act_window">
        <field name="name">Contratos de Compra</field>
        <field name="res_model">pi.contract</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

</odoo>
