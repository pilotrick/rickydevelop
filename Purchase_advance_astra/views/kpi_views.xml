<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_purchase_intelligence_kpi_tree" model="ir.ui.view">
            <field name="name">purchase.intelligence.kpi.tree</field>
            <field name="model">purchase.intelligence.kpi</field>
            <field name="arch" type="xml">
                <list string="KPIs de Compras">
                    <field name="name"/>
                    <field name="category"/>
                    <field name="value"/>
                    <field name="target"/>
                    <field name="variance" widget="percentage"/>
                    <field name="trend"/>
                    <field name="status" widget="badge" decoration-success="status == 'success'" decoration-warning="status == 'warning'" decoration-danger="status == 'danger'"/>
                </list>
            </field>
        </record>

        <record id="view_purchase_intelligence_kpi_form" model="ir.ui.view">
            <field name="name">purchase.intelligence.kpi.form</field>
            <field name="model">purchase.intelligence.kpi</field>
            <field name="arch" type="xml">
                <form string="KPI de Compras">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="category"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="value"/>
                                <field name="target"/>
                                <field name="previous_value"/>
                            </group>
                        </group>
                        <group string="Análisis">
                            <field name="variance"/>
                            <field name="trend"/>
                            <field name="status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_purchase_intelligence_kpi_graph" model="ir.ui.view">
            <field name="name">purchase.intelligence.kpi.graph</field>
            <field name="model">purchase.intelligence.kpi</field>
            <field name="arch" type="xml">
                <graph string="Análisis de KPI" type="bar">
                    <field name="category"/>
                    <field name="value" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_purchase_intelligence_kpi_search" model="ir.ui.view">
            <field name="name">purchase.intelligence.kpi.search</field>
            <field name="model">purchase.intelligence.kpi</field>
            <field name="arch" type="xml">
                <search string="Buscar KPI">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="category"/>
                    <filter string="Por Categoría" name="group_by_category" context="{'group_by':'category'}"/>
                    <filter string="Por Fecha" name="group_by_date" context="{'group_by':'date'}"/>
                </search>
            </field>
        </record>

        <!-- KPI Action -->
        <record id="action_purchase_intelligence_kpi" model="ir.actions.act_window">
            <field name="name">KPIs de Compras</field>
            <field name="res_model">purchase.intelligence.kpi</field>
            <field name="view_mode">list,form,graph</field>
            <field name="search_view_id" ref="view_purchase_intelligence_kpi_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay KPIs registrados aún
                </p>
                <p>
                    Los KPIs se calculan automáticamente para medir el rendimiento de compras.
                </p>
            </field>
        </record>

</odoo>
