<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Vista de formulario de producto con información de inteligencia -->
    <record id="view_product_template_form_inherit_pi" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pi</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="🧠 Inteligencia de Stock" name="stock_intelligence">
                    <div class="alert alert-info" role="alert">
                        <strong>ℹ️ Análisis Automático:</strong> Los datos se calculan automáticamente cada 6 horas basándose en los movimientos de stock reales.
                    </div>
                    <group>
                        <group string="Estado Actual">
                            <field name="qty_available" string="Stock Disponible"/>
                            <field name="days_of_stock" string="Días de Stock"/>
                            <field name="stockout_risk" widget="badge"
                                   decoration-danger="stockout_risk in ('critical', 'high')"
                                   decoration-warning="stockout_risk == 'medium'"
                                   decoration-success="stockout_risk in ('low', 'none')"/>
                            <field name="needs_reorder" widget="boolean_toggle"/>
                        </group>
                        <group string="Consumo (Calculado)">
                            <field name="daily_usage" string="Consumo Diario"/>
                            <field name="weekly_usage" string="Consumo Semanal"/>
                            <field name="monthly_usage" string="Consumo Mensual"/>
                            <field name="lead_time_days" string="Tiempo de Entrega"/>
                        </group>
                    </group>
                    <group>
                        <group string="Niveles de Stock (Automáticos)">
                            <field name="safety_stock" string="Stock de Seguridad"/>
                            <field name="reorder_point" string="Punto de Reorden"/>
                            <field name="max_stock" string="Stock Máximo"/>
                            <field name="eoq" string="Cantidad Óptima de Pedido"/>
                        </group>
                        <group string="Sugerencia de Compra">
                            <field name="suggested_order_qty" string="Cantidad Sugerida"/>
                        </group>
                    </group>
                    <group>
                        <group string="Clasificación">
                            <field name="abc_classification" widget="badge"/>
                            <field name="fsn_classification" widget="badge"/>
                            <field name="ved_classification"/>
                        </group>
                    </group>

                    <separator string="📊 Detalle por Almacén" style="margin-top: 20px;"/>
                    <field name="warehouse_intelligence_ids" mode="kanban">
                        <kanban string="Análisis por Almacén" class="o_kanban_dashboard">
                            <field name="warehouse_id"/>
                            <field name="qty_available"/>
                            <field name="stockout_risk"/>
                            <field name="days_of_stock"/>
                            <field name="needs_reorder"/>
                            <field name="suggested_order_qty"/>
                            <field name="reorder_point"/>
                            <field name="daily_usage"/>
                            <field name="weekly_usage"/>
                            <field name="monthly_usage"/>
                            <field name="safety_stock"/>
                            <field name="max_stock"/>
                            <field name="eoq"/>
                            <field name="lead_time_days"/>
                            <field name="abc_classification"/>
                            <field name="fsn_classification"/>
                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_card_header">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong class="h5 mb-0"><field name="warehouse_id"/></strong>
                                            <field name="stockout_risk" widget="badge" 
                                                   decoration-danger="stockout_risk in ('critical', 'high')"
                                                   decoration-warning="stockout_risk == 'medium'"
                                                   decoration-success="stockout_risk in ('low', 'none')"/>
                                        </div>
                                    </div>
                                    
                                    <div class="container-fluid p-0">
                                        <!-- Sección Principal: Stock y Riesgo -->
                                        <div class="row mb-3 bg-light p-2 rounded mx-0">
                                            <div class="col-6 text-center border-end">
                                                <small class="text-muted text-uppercase">Disponible</small>
                                                <h4 class="mb-0 text-primary"><field name="qty_available"/></h4>
                                            </div>
                                            <div class="col-6 text-center">
                                                <small class="text-muted text-uppercase">Días Stock</small>
                                                <h4 class="mb-0" t-att-class="record.days_of_stock.value &lt; 7 ? 'text-danger' : 'text-success'">
                                                    <field name="days_of_stock"/>
                                                </h4>
                                            </div>
                                        </div>

                                        <!-- Sección de Consumo -->
                                        <div class="row mb-2">
                                            <div class="col-12">
                                                <h6 class="text-uppercase text-muted border-bottom pb-1" style="font-size: 0.75rem;">Consumo (Calc)</h6>
                                            </div>
                                            <div class="col-4 px-1 text-center">
                                                <small class="text-muted d-block">Diario</small>
                                                <span class="fw-bold"><field name="daily_usage"/></span>
                                            </div>
                                            <div class="col-4 px-1 text-center border-start border-end">
                                                <small class="text-muted d-block">Mensual</small>
                                                <span class="fw-bold"><field name="monthly_usage"/></span>
                                            </div>
                                            <div class="col-4 px-1 text-center">
                                                <small class="text-muted d-block">Lead Time</small>
                                                <span class="fw-bold"><field name="lead_time_days"/> d</span>
                                            </div>
                                        </div>

                                        <!-- Sección de Niveles -->
                                        <div class="row mb-2">
                                            <div class="col-12">
                                                <h6 class="text-uppercase text-muted border-bottom pb-1" style="font-size: 0.75rem;">Niveles Automáticos</h6>
                                            </div>
                                            <div class="col-6 mb-1 d-flex justify-content-between">
                                                <span class="text-muted small">Seguridad:</span>
                                                <span class="fw-bold"><field name="safety_stock"/></span>
                                            </div>
                                            <div class="col-6 mb-1 d-flex justify-content-between">
                                                <span class="text-muted small">Pto Reorden:</span>
                                                <span class="fw-bold"><field name="reorder_point"/></span>
                                            </div>
                                            <div class="col-6 d-flex justify-content-between">
                                                <span class="text-muted small">EOQ:</span>
                                                <span class="fw-bold"><field name="eoq"/></span>
                                            </div>
                                            <div class="col-6 d-flex justify-content-between">
                                                <span class="text-muted small">Max:</span>
                                                <span class="fw-bold"><field name="max_stock"/></span>
                                            </div>
                                        </div>

                                        <!-- Sugerencia y Acción -->
                                        <t t-if="record.needs_reorder.raw_value">
                                            <div class="alert alert-danger mt-2 mb-0 p-2 text-center" role="alert">
                                                <strong>⚠️ PEDIR: <field name="suggested_order_qty"/></strong>
                                            </div>
                                        </t>
                                        
                                        <!-- Footer: Clasificación -->
                                        <div class="row mt-2 pt-2 border-top">
                                            <div class="col-12 d-flex justify-content-between">
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    ABC: <field name="abc_classification"/>
                                                </span>
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    FSN: <field name="fsn_classification"/>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Vista de lista de productos con indicadores de riesgo -->
    <record id="view_product_template_tree_inherit_pi" model="ir.ui.view">
        <field name="name">product.template.list.inherit.pi</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="qty_available" position="after">
                <field name="days_of_stock" optional="show"/>
                <field name="stockout_risk" widget="badge" optional="show"
                       decoration-danger="stockout_risk in ('critical', 'high')"
                       decoration-warning="stockout_risk == 'medium'"
                       decoration-success="stockout_risk in ('low', 'none')"/>
                <field name="needs_reorder" widget="boolean" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- Vista de formulario para Intelligence por Almacén -->
    <record id="view_product_warehouse_intelligence_form" model="ir.ui.view">
        <field name="name">pi.product.warehouse.intelligence.form</field>
        <field name="model">pi.product.warehouse.intelligence</field>
        <field name="arch" type="xml">
            <form string="Inteligencia por Almacén">
                <sheet>
                    <group>
                        <group string="Estado Actual">
                            <field name="warehouse_id" readonly="1"/>
                            <field name="qty_available"/>
                            <field name="days_of_stock"/>
                            <field name="stockout_risk" widget="badge"
                                   decoration-danger="stockout_risk in ('critical', 'high')"
                                   decoration-warning="stockout_risk == 'medium'"
                                   decoration-success="stockout_risk in ('low', 'none')"/>
                        </group>
                        <group string="Consumo">
                            <field name="daily_usage"/>
                            <field name="weekly_usage"/>
                            <field name="monthly_usage"/>
                            <field name="lead_time_days"/>
                        </group>
                    </group>
                    <group>
                        <group string="Niveles Óptimos">
                            <field name="safety_stock"/>
                            <field name="reorder_point"/>
                            <field name="max_stock"/>
                            <field name="eoq"/>
                        </group>
                        <group string="Recomendaciones">
                            <field name="needs_reorder" widget="boolean_toggle"/>
                            <field name="suggested_order_qty"/>
                            <field name="suggestion_state" widget="badge" 
                                   decoration-danger="suggestion_state == 'reorder'"
                                   decoration-info="suggestion_state == 'overstock'"
                                   decoration-success="suggestion_state == 'normal'"/>
                        </group>
                    </group>
                    <group string="Clasificación">
                        <group>
                            <field name="abc_classification" widget="badge"/>
                        </group>
                        <group>
                            <field name="fsn_classification" widget="badge"/>
                            <field name="ved_classification"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Kanban para Intelligence por Almacén -->
    <record id="view_product_warehouse_intelligence_kanban" model="ir.ui.view">
        <field name="name">pi.product.warehouse.intelligence.kanban</field>
        <field name="model">pi.product.warehouse.intelligence</field>
        <field name="arch" type="xml">
            <kanban string="Análisis por Almacén">
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_title">
                            <strong><field name="warehouse_id"/></strong>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">
                                <span class="text-muted">Stock:</span> <field name="qty_available"/>
                            </div>
                            <div class="col-6 text-end">
                                <field name="stockout_risk" widget="badge" 
                                       decoration-danger="stockout_risk in ('critical', 'high')"
                                       decoration-warning="stockout_risk == 'medium'"
                                       decoration-success="stockout_risk in ('low', 'none')"/>
                            </div>
                        </div>
                        <div class="row mt-1">
                            <div class="col-12">
                                <span class="text-muted">Días Stock:</span> <field name="days_of_stock"/>
                            </div>
                        </div>
                         <div class="row mt-1" invisible="not needs_reorder">
                            <div class="col-12 text-danger">
                                <strong>Pedir: <field name="suggested_order_qty"/></strong>
                            </div>
                        </div>
                         <div class="row mt-2 pt-2 border-top">
                            <div class="col-6 text-muted small">
                                ROP: <field name="reorder_point"/>
                            </div>
                            <div class="col-6 text-end text-muted small">
                                Uso: <field name="daily_usage"/>/día
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción para ver productos que necesitan pedido -->
    <record id="action_products_need_reorder" model="ir.actions.act_window">
        <field name="name">Productos que Necesitan Pedido</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'product'), ('needs_reorder', '=', True)]</field>
        <field name="context">{'search_default_group_by_categ': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Excelente! No hay productos que necesiten pedido
            </p>
            <p>
                El sistema analiza automáticamente tu inventario y detecta productos
                que están por debajo del punto de reorden.
            </p>
        </field>
    </record>

    <!-- Acción para productos críticos -->
    <record id="action_products_critical_risk" model="ir.actions.act_window">
        <field name="name">Productos Críticos (Riesgo Alto)</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'product'), ('stockout_risk', 'in', ['critical', 'high'])]</field>
    </record>

</odoo>
