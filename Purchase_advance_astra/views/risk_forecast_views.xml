<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Forecast Accuracy Views -->
    <record id="view_pi_forecast_accuracy_tree" model="ir.ui.view">
        <field name="name">pi.forecast.accuracy.tree</field>
        <field name="model">pi.forecast.accuracy</field>
        <field name="arch" type="xml">
            <list string="Precisión de Pronósticos">
                <field name="date"/>
                <field name="product_id"/>
                <field name="forecasted_qty"/>
                <field name="actual_qty"/>
                <field name="accuracy_percent" widget="progressbar"/>
                <field name="method"/>
            </list>
        </field>
    </record>

    <record id="view_pi_forecast_accuracy_form" model="ir.ui.view">
        <field name="name">pi.forecast.accuracy.form</field>
        <field name="model">pi.forecast.accuracy</field>
        <field name="arch" type="xml">
            <form string="Precisión de Pronóstico">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="date"/>
                            <field name="forecast_id"/>
                            <field name="method"/>
                        </group>
                        <group>
                            <field name="forecasted_qty"/>
                            <field name="actual_qty"/>
                            <field name="accuracy_percent" widget="progressbar"/>
                            <field name="error_absolute"/>
                            <field name="error_percent"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Risk Assessment Views -->
    <record id="view_pi_risk_assessment_tree" model="ir.ui.view">
        <field name="name">pi.risk.assessment.tree</field>
        <field name="model">pi.risk.assessment</field>
        <field name="arch" type="xml">
            <list string="Evaluación de Riesgos" decoration-danger="risk_level=='critical'" decoration-warning="risk_level=='high'">
                <field name="date"/>
                <field name="name"/>
                <field name="risk_type"/>
                <field name="partner_id"/>
                <field name="risk_score"/>
                <field name="risk_level" widget="badge" decoration-danger="risk_level=='critical'" decoration-warning="risk_level=='high'" decoration-info="risk_level=='medium'" decoration-success="risk_level=='low'"/>
                <field name="mitigation_status"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_pi_risk_assessment_form" model="ir.ui.view">
        <field name="name">pi.risk.assessment.form</field>
        <field name="model">pi.risk.assessment</field>
        <field name="arch" type="xml">
            <form string="Evaluación de Riesgo">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="identified,assessed,mitigating,monitored,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Descripción del riesgo..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="risk_type"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="probability"/>
                            <field name="impact"/>
                            <field name="risk_score" readonly="1"/>
                            <field name="risk_level" widget="badge" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="responsible_id"/>
                            <field name="mitigation_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Plan de Mitigación">
                            <field name="mitigation_plan" placeholder="Describa el plan de mitigación..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_pi_forecast_accuracy" model="ir.actions.act_window">
        <field name="name">Precisión de Pronósticos</field>
        <field name="res_model">pi.forecast.accuracy</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_pi_risk_assessment" model="ir.actions.act_window">
        <field name="name">Evaluación de Riesgos</field>
        <field name="res_model">pi.risk.assessment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
