<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_pi_savings_tracker_tree" model="ir.ui.view">
        <field name="name">pi.savings.tracker.tree</field>
        <field name="model">pi.savings.tracker</field>
        <field name="arch" type="xml">
            <list string="Rastreador de Ahorros">
                <field name="name"/>
                <field name="date"/>
                <field name="savings_type"/>
                <field name="amount_estimated" sum="Total Estimado"/>
                <field name="amount_captured" sum="Total Capturado"/>
                <field name="status" widget="badge" decoration-success="status == 'realized'"/>
            </list>
        </field>
    </record>

    <record id="view_pi_savings_tracker_form" model="ir.ui.view">
        <field name="name">pi.savings.tracker.form</field>
        <field name="model">pi.savings.tracker</field>
        <field name="arch" type="xml">
            <form string="Oportunidad de Ahorro">
                <header>
                    <field name="status" widget="statusbar" clickable="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="category_id"/>
                            <field name="savings_type"/>
                        </group>
                        <group>
                            <field name="amount_estimated"/>
                            <field name="amount_captured"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Savings Tracker Action -->
    <record id="action_pi_savings_tracker" model="ir.actions.act_window">
        <field name="name">Rastreador de Ahorros</field>
        <field name="res_model">pi.savings.tracker</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
