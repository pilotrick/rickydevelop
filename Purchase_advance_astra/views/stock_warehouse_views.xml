<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_form_inherit_intelligence" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.intelligence</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="active_intelligence" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
